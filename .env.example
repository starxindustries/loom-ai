# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Supabase  (project settings → API)
# https://app.supabase.com/project/_/settings/api
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI  (chat + memory extraction)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — primary app sign-in
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — integration (Gmail send / Calendar) — separate app
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Other integration providers
# ─────────────────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Lemonsqueezy  (billing)
# ─────────────────────────────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_IDS=                       # comma-separated variant ids

# ─────────────────────────────────────────────────────────────────────────────
# Internal / admin (server-to-server only)
# ─────────────────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=
ADMIN_API_TOKEN=
